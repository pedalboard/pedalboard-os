# Pedalboard system configuration

# ALSA sound card name (stable across reboots, unlike card numbers)
# Find with: cat /proc/asound/cards
AUDIO_CARD=sndrpihifiberry

# JACK MIDI auto-connect pattern (case-insensitive substring match)
MIDI_MATCH=pedalboard-midi

# Bridge HTTP/WebSocket port
BRIDGE_PORT=8080
